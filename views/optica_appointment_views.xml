<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_optica_appointment_tree" model="ir.ui.view">
        <field name="name">optica.appointment.tree</field>
        <field name="model">optica.appointment</field>
        <field name="arch" type="xml">
            <tree string="Citas">
                <field name="appointment_datetime"/>
                <field name="appointment_end_datetime"/>
                <field name="patient_name"/>
                <field name="partner_id"/>
                <field name="phone"/>
                <field name="appointment_type"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_optica_appointment_form" model="ir.ui.view">
        <field name="name">optica.appointment.form</field>
        <field name="model">optica.appointment</field>
        <field name="arch" type="xml">
            <form string="Cita Óptica">
                <header>
                    <button
                        name="action_confirm"
                        type="object"
                        string="Confirmar"
                        class="btn-primary"
                        invisible="state != 'draft'"
                    />
                    <button
                        name="action_done"
                        type="object"
                        string="Marcar como realizada"
                        class="btn-success"
                        invisible="state != 'confirmed'"
                    />
                    <button
                        name="action_cancel"
                        type="object"
                        string="Cancelar"
                        class="btn-secondary"
                        invisible="state in ['cancelled', 'done']"
                    />
                    <button
                        name="action_reset_to_draft"
                        type="object"
                        string="Regresar a pendiente"
                        invisible="state == 'draft'"
                    />
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="patient_name" placeholder="Nombre del paciente"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Paciente">
                            <field name="partner_id"/>
                            <field name="phone"/>
                            <field name="whatsapp"/>
                            <field name="email"/>
                        </group>

                        <group string="Cita">
                            <field name="appointment_type"/>
                            <field name="appointment_date"/>
                            <field name="appointment_time" widget="float_time"/>
                            <field name="duration" widget="float_time"/>
                            <field name="appointment_datetime" readonly="1"/>
                            <field name="appointment_end_datetime" readonly="1"/>
                            <field name="calendar_event_id" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Motivo">
                            <field name="reason"/>
                        </page>

                        <page string="Notas internas">
                            <field name="internal_notes"/>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_optica_appointment_calendar" model="ir.ui.view">
        <field name="name">optica.appointment.calendar</field>
        <field name="model">optica.appointment</field>
        <field name="arch" type="xml">
            <calendar
                string="Citas"
                date_start="appointment_datetime"
                date_stop="appointment_end_datetime"
                color="state"
                mode="week"
            >
                <field name="patient_name"/>
                <field name="appointment_type"/>
                <field name="phone"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="view_optica_appointment_search" model="ir.ui.view">
        <field name="name">optica.appointment.search</field>
        <field name="model">optica.appointment</field>
        <field name="arch" type="xml">
            <search string="Buscar citas">
                <field name="patient_name"/>
                <field name="partner_id"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="appointment_type"/>
                <field name="state"/>

                <filter
                    name="upcoming"
                    string="Próximas"
                    domain="[('appointment_datetime', '&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]"
                />

                <filter
                    name="draft"
                    string="Pendientes"
                    domain="[('state', '=', 'draft')]"
                />

                <filter
                    name="confirmed"
                    string="Confirmadas"
                    domain="[('state', '=', 'confirmed')]"
                />

                <filter
                    name="done"
                    string="Realizadas"
                    domain="[('state', '=', 'done')]"
                />

                <filter
                    name="cancelled"
                    string="Canceladas"
                    domain="[('state', '=', 'cancelled')]"
                />

                <group expand="0" string="Agrupar por">
                    <filter
                        name="group_by_state"
                        string="Estado"
                        context="{'group_by': 'state'}"
                    />
                    <filter
                        name="group_by_type"
                        string="Tipo de cita"
                        context="{'group_by': 'appointment_type'}"
                    />
                    <filter
                        name="group_by_date"
                        string="Fecha"
                        context="{'group_by': 'appointment_date'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <record id="action_optica_appointment" model="ir.actions.act_window">
        <field name="name">Citas</field>
        <field name="res_model">optica.appointment</field>
        <field name="view_mode">tree,form,calendar</field>
        <field name="context">{'search_default_upcoming': 1}</field>
    </record>

    <menuitem
        id="menu_optica_appointment_root"
        name="Citas Óptica"
        sequence="10"
    />

    <menuitem
        id="menu_optica_appointment"
        name="Citas"
        parent="menu_optica_appointment_root"
        action="action_optica_appointment"
        sequence="10"
    />

</odoo>
